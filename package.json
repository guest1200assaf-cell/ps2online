{
  "name": "ps2-online",
  "version": "1.0.0",
  "description": "Assaf Station - العب مع صديقك",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "discord-rpc": "^4.0.1",
    "node-7z": "^3.0.0",
    "socket.io-client": "^4.7.2",
    "webtorrent": "^2.8.5"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ps2online.app",
    "productName": "Assaf Station",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "ar",
        "en_US"
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*"
    ]
  }
}
